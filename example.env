# Explosion Boy server configuration
# Copy this file to .env and adjust as needed.

# Address the server binds to. Use 0.0.0.0 to accept connections on all interfaces.
SERVER_HOST=0.0.0.0

# Port the server listens on.
SERVER_PORT=9000

# Transport backend. Currently only 'tcp' is supported.
SERVER_BACKEND=tcp

# Host-side port that Docker maps to SERVER_PORT.
# Change this if SERVER_PORT is already in use on your machine.
HOST_PORT=9000
